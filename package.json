{
	"name": "n8n-nodes-centum-v2",
	"version": "0.1.6",
	"description": "n8n community node for working with the Centum ERP API across customers, sales, purchases, stock, logistics, and supporting resources.",
	"keywords": [
		"n8n",
		"n8n-community-node-package",
		"centum",
		"erp",
		"integration"
	],
	"license": "MIT",
	"homepage": "https://github.com/gauchocode/n8n-nodes-centum#readme",
	"author": {
		"name": "GauchoCode"
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/gauchocode/n8n-nodes-centum.git"
	},
	"engines": {
		"node": ">=20.15"
	},
	"main": "dist/nodes/Centum/Centum.node.js",
	"scripts": {
		"clean": "rm -rf dist",
		"build": "npm run clean && tsc && gulp build:icons",
		"build:automate": "cd dist && npm install --omit=dev",
		"dev": "tsc --watch",
		"format": "prettier nodes credentials --write",
		"lint": "eslint nodes credentials package.json",
		"lintfix": "eslint nodes credentials package.json --fix",
		"prepublishOnly": "npm run build && npm run lint -c .eslintrc.prepublish.js nodes credentials package.json",
		"scan": "node scripts/scan-local-community-package.mjs"
	},
	"files": [
		"dist"
	],
	"n8n": {
		"n8nNodesApiVersion": 1,
		"credentials": [
			"dist/credentials/CentumApi.credentials.js"
		],
		"nodes": [
			"dist/nodes/Centum/Centum.node.js"
		]
	},
	"devDependencies": {
		"@n8n/scan-community-package": "^0.12.0",
		"@types/express": "^4.17.6",
		"@types/request-promise-native": "~1.0.15",
		"@typescript-eslint/parser": "~8.32.0",
		"eslint": "^8.57.0",
		"eslint-plugin-n8n-nodes-base": "^1.16.3",
		"gulp": "^5.0.0",
		"prettier": "^3.5.3",
		"typescript": "^5.8.2"
	},
	"peerDependencies": {
		"n8n-workflow": "*"
	}
}
